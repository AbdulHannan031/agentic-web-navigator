# Copy to .env and fill in. The agent service reads these at startup.

# Required: OpenAI key for GPT-4o mini
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown)
NAV_MODEL=gpt-4o-mini
NAV_TEMPERATURE=0.1
NAV_CDP_PORT=9222
NAV_WS_HOST=127.0.0.1
NAV_WS_PORT=8787
NAV_MAX_STEPS=40
NAV_STEALTH=1
NAV_LOG_LEVEL=INFO

# Optional external CAPTCHA solver (off by default). e.g. NAV_CAPTCHA_SOLVER=2captcha
NAV_CAPTCHA_SOLVER=
NAV_SOLVER_API_KEY=
